{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022"],
		"strict": true,
		"noEmit": true,
		"allowJs": true,
		"checkJs": false,
		"types": ["@cloudflare/workers-types"],
		"skipLibCheck": true
	},
	"include": [
		"**/*.ts",
		"**/*.js"
	],
	"exclude": [
		"node_modules"
	]
}